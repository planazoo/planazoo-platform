# Fastlane para unp_calendario (iOS)
# Ejecutar desde la raíz del proyecto o desde ios/:
#   cd ios && bundle exec fastlane beta
#   cd ios && bundle exec fastlane release

default_platform(:ios)

# Directorio donde Flutter genera el IPA (flutter build ipa desde la raíz del proyecto)
FLUTTER_IPA_DIR = File.expand_path("../../build/ios/ipa", __dir__)
# Nombre por defecto (pubspec name); Flutter a veces genera otro (p. ej. Runner.ipa)
def find_ipa_path
  default = File.join(FLUTTER_IPA_DIR, "unp_calendario.ipa")
  return default if File.exist?(default)
  Dir.glob(File.join(FLUTTER_IPA_DIR, "*.ipa")).first || default
end

platform :ios do
  desc "Solo compilar IPA (sin subir). Útil para comprobar que el build funciona sin tener cuenta Apple activa."
  lane :build_only do
    project_root = File.expand_path("../..", __dir__)
    sh("cd #{project_root} && flutter build ipa")
    ipa_path = find_ipa_path
    unless File.exist?(ipa_path)
      UI.user_error!("El build no generó el IPA. Buscado en: #{FLUTTER_IPA_DIR}")
    end
    UI.success("IPA generado correctamente: #{ipa_path}")
  end

  desc "Subir build a TestFlight (beta)"
  lane :beta do
    # Opción 1: Asumir que ya corriste `flutter build ipa` desde la raíz del proyecto
    # Opción 2: Descomenta la siguiente línea para que la lane ejecute el build
    # sh("cd #{File.expand_path('../..', __dir__)} && flutter build ipa")

    ipa_path = find_ipa_path
    unless File.exist?(ipa_path)
      UI.user_error!("No se encontró el IPA. Ejecuta desde la raíz: flutter build ipa. Buscado en: #{FLUTTER_IPA_DIR}")
    end

    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      # changelog: "Cambios en esta versión beta"
    )
  end

  desc "Subir build a App Store (release)"
  lane :release do
    ipa_path = find_ipa_path
    unless File.exist?(ipa_path)
      UI.user_error!("No se encontró el IPA. Ejecuta desde la raíz: flutter build ipa. Buscado en: #{FLUTTER_IPA_DIR}")
    end

    upload_to_app_store(
      ipa: ipa_path,
      submit_for_review: false,
      force: true
    )
  end
end
