# Configuración de la app para Fastlane (iOS)
# Sustituye los valores placeholder por los de tu cuenta Apple / App Store Connect.
# team_id: Developer Portal (Membership) → Team ID
# itc_team_id: App Store Connect → Users and Access → Team ID (puede ser el mismo)

app_identifier("com.mycompany.myplanazoo")
